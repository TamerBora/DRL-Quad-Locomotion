# Ignore everything by default
/*
robot_lab/

# Unignore only the tracked components
!.gitignore
!README.md
!requirements.txt
!setup_task_configs.sh
!launchers/
!robot_lab/

# Track task_configs (modified robot_lab files)
!task_configs/

# Within launchers, only track specific subdirectories
launchers/*
!launchers/go2w_SAC_sbx/
!launchers/go2w_GSAC_sbx/
!launchers/go2w_flashsac/
!launchers/go2w_flashGSAC/
!launchers/sbx_source/
launchers/sbx_source/*
!launchers/sbx_source/gsac/

# Exclude go2w_flashsac runtime artifacts and the cloned FlashSAC repo
launchers/go2w_flashsac/FlashSAC/
launchers/go2w_flashsac/logs/
launchers/go2w_flashsac/wandb/

# Exclude go2w_flashGSAC runtime artifacts
launchers/go2w_flashGSAC/logs/
launchers/go2w_flashGSAC/wandb/

# Exclude logs (model checkpoints, tensorboard — too large)
launchers/go2w_SAC_sbx/logs/
launchers/go2w_GSAC_sbx/logs/

# Within robot_lab, exclude heavy data assets and build artifacts
robot_lab/source/robot_lab/data/
robot_lab/source/robot_lab/robot_lab.egg-info/
robot_lab/**/__pycache__/
robot_lab/**/*.pyc
robot_lab/docker/
robot_lab/docs/

# Python / general
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.zip
*.pt
*.pth

# Whitelist the pinned v4 inference checkpoint (3.3 MB, needed to revert to
# the best SAC policy without retraining). Critic files are not whitelisted
# — they are 35 MB and only useful for resuming training.
!launchers/go2w_flashsac/v4_checkpoint/step_19998720/actor.pt
!launchers/go2w_flashsac/v4_checkpoint/step_19998720/temperature.pt
!launchers/go2w_flashsac/v4_checkpoint/step_19998720/reward_normalizer.pt
!launchers/go2w_flashsac/v4_checkpoint/step_19998720/agent_state.pt
